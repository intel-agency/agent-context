{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "instructions": ["AGENTS.md"],
  "default_agent": "orchestrator",
  "model": "zai-coding-plan/glm-5.2",
  "small_model": "google/gemini-3.5-flash",
  "permission": {
    "websearch": "allow",
  },
  "mcp": {
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking",
      ],
    },
    "memory-graph": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"],
      "environment": {
      },
    },
    "web-reader": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_reader/mcp",
      "headers": {
        "Authorization": "{env:Z_AI_API_KEY}",
      },
    },
    "zread": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/zread/mcp",
      "headers": {
        "Authorization": "{env:Z_AI_API_KEY}",
      },
    },
    "web-search-prime": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_search_prime/mcp",
      "headers": {
        "Authorization": "{env:Z_AI_API_KEY}",
      },
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,web_fetch_exa,web_search_advanced_exa,get_code_context_exa,crawling_exa&exaApiKey={env:EXA_API_KEY}",
      "enabled": true,
    },
  },
  "provider": {
    // Z.AI Coding Plan — built-in provider (creds resolved from auth.json;
    // env fallback ZAI_CODING_PLAN_OPEN_AI_API_KEY / Z_AI_API_KEY).
    "zai-coding-plan": {
      "models": {
        "glm-5.2": {
          "name": "GLM 5.2",
        },
        "glm-4.7": {
          "name": "GLM 4.7",
        },
        "glm-4.5-air": {
          "name": "GLM 4.5 Air",
        },
      },
    },
    // OpenCode Go subscription — built-in provider (creds resolved from
    // auth.json; env fallback OPENCODE_GO_API_KEY).
    "opencode-go": {
      "models": {
        // @ai-sdk/openai-compatible  — https://opencode.ai/zen/go/v1/chat/completions
        "glm-5.2": {
          "name": "GLM 5.2",
        },
        "glm-5.1": {
          "name": "GLM 5.1",
        },
        "kimi-k2.7-code": {
          "name": "Kimi K2.7 Code",
        },
        "kimi-k2.6": {
          "name": "Kimi K2.6",
        },
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro",
        },
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash",
        },
        "mimo-v2.5": {
          "name": "MiMo V2.5",
        },
        "mimo-v2.5-pro": {
          "name": "MiMo V2.5 Pro",
        },
        // @ai-sdk/anthropic          — https://opencode.ai/zen/go/v1/messages
        "minimax-m3": {
          "name": "MiniMax M3",
        },
        "minimax-m2.7": {
          "name": "MiniMax M2.7",
        },
        "minimax-m2.5": {
          "name": "MiniMax M2.5",
        },
        "qwen3.7-max": {
          "name": "Qwen 3.7 Max",
        },
        "qwen3.7-plus": {
          "name": "Qwen 3.7 Plus",
        },
        "qwen3.6-plus": {
          "name": "Qwen 3.6 Plus",
        },
      },
    },
    // Google AI Studio — built-in provider, reads GEMINI_API_KEY from env.
    "google": {
      "models": {
        "gemini-3.5-flash": {
          "name": "Gemini 3.5 Flash",
        },
      },
    },
    // NVIDIA NIM — built-in provider (build.nvidia.com). Credentials and the
    // NIM base URL are resolved from env: NVIDIA_NIM_API_KEY and
    // NVIDIA_NIM_BASE_URL (defaults to https://integrate.api.nvidia.com/v1).
    // The built-in "nvidia" provider normally reads NVIDIA_API_KEY, so the
    // apiKey option below overrides it to use the NIM key.
    "nvidia": {
      "options": {
        "apiKey": "{env:NVIDIA_NIM_API_KEY}",
        "baseURL": "{env:NVIDIA_NIM_BASE_URL}",
      },
      "models": {
        "minimaxai/minimax-m3": {
          "name": "MiniMax M3",
          "tool_call": true,
        },
      },
    },
    // Cline Pass — Cline's low-cost subscription ($9.99/month) giving
    // reliable access to open coding models with 2-5x API rate limits.
    // OpenAI-compatible endpoint; API key resolved from env: CLINE_API_KEY.
    "cline-pass": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Cline Pass",
      "options": {
        "apiKey": "{env:CLINE_API_KEY}",
        "baseURL": "https://api.cline.bot/api/v1",
      },
      "models": {
        "cline-pass/glm-5.2": {
          "name": "GLM 5.2",
        },
        "cline-pass/kimi-k2.7-code": {
          "name": "Kimi K2.7 Code",
        },
        "cline-pass/kimi-k2.6": {
          "name": "Kimi K2.6",
        },
        "cline-pass/deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro",
        },
        "cline-pass/deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash",
        },
        "cline-pass/mimo-v2.5": {
          "name": "MiMo V2.5",
        },
        "cline-pass/mimo-v2.5-pro": {
          "name": "MiMo V2.5 Pro",
        },
        "cline-pass/minimax-m3": {
          "name": "MiniMax M3",
        },
        "cline-pass/qwen3.7-max": {
          "name": "Qwen 3.7 Max",
        },
        "cline-pass/qwen3.7-plus": {
          "name": "Qwen 3.7 Plus",
        },
      },
    },
    // // Alibaba Cloud Model Studio (Bailian / DashScope) — uses the
    // // Anthropic-compatible endpoint via @ai-sdk/anthropic (recommended for
    // // OpenCode: tool-calling + thinking support). API key resolved from env:
    // // DASHSCOPE_API_KEY. The baseURL below is the China (Beijing)
    // // pay-as-you-go endpoint; swap in another plan/region as needed:
    // //   Singapore PAYG:    https://{WorkspaceId}.ap-southeast-1.maas.aliyuncs.com/apps/anthropic/v1
    // //   Coding Plan:       https://coding.dashscope.aliyuncs.com/apps/anthropic/v1
    // //   Token Plan (Team): https://token-plan.cn-beijing.maas.aliyuncs.com/apps/anthropic/v1
    // "alibaba-model-studio": {
    //   "npm": "@ai-sdk/anthropic",
    //   "name": "Alibaba Cloud Model Studio",
    //   "options": {
    //     "apiKey": "{env:DASHSCOPE_API_KEY}",
    //     "baseURL": "https://dashscope.aliyuncs.com/apps/anthropic/v1",
    //   },
    //   "models": {
    //     "qwen3.6-plus": {
    //       "name": "Qwen3.6 Plus",
    //       "modalities": {
    //         "input": ["text", "image"],
    //         "output": ["text"],
    //       },
    //       "options": {
    //         "thinking": {
    //           "type": "enabled",
    //           "budgetTokens": 8192,
    //         },
    //       },
    //     },
    //     "qwen3.7-plus": {
    //       "name": "Qwen3.7 Plus",
    //       "modalities": {
    //         "input": ["text", "image"],
    //         "output": ["text"],
    //       },
    //       "options": {
    //         "thinking": {
    //           "type": "enabled",
    //           "budgetTokens": 8192,
    //         },
    //       },
    //     },
    //   },
    // },
  },
}
